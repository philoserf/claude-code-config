# Runtime state — owned by the Claude Code runtime, not for version control
/sessions/
/cache/
/shell-snapshots/
/session-env/
/backups/
/file-history/
/ide/
/plans/
/paste-cache/
/history.jsonl
/mcp-needs-auth-cache.json
/.last-cleanup

# Credentials & auth — must never be committed
/.credentials.json
/mcp-client-secrets.json
*credentials*.json

# Telemetry, logs, and diagnostics (may or may not exist yet)
/telemetry/
/logs/
*.log
/heapdump-*.heapsnapshot
/heapdump-breakdown.txt

# Machine-local settings (per Claude Code convention)
/settings.local.json
/.claude/settings.local.json

# Per-project state — entirely runtime-owned and CWD-hash-keyed
# (memories live under projects/<hash>/memory/ but the hash makes them
# non-portable across machines; back up specific files with `git add -f` if needed)
/projects/

# Editor / OS noise
.DS_Store
*.swp
.idea/
.vscode/
