{
  "attribution": {
    "commit": "Co-Authored-By: Claude",
    "pr": ""
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "sh /Users/markayers/.claude/hooks/auto-format-md.sh",
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "agent_needs_input",
        "hooks": [
          {
            "type": "command",
            "command": "sh /Users/markayers/.claude/hooks/notify-agent.sh needs-input",
            "async": true
          }
        ]
      },
      {
        "matcher": "agent_completed",
        "hooks": [
          {
            "type": "command",
            "command": "sh /Users/markayers/.claude/hooks/notify-agent.sh completed",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "sh /Users/markayers/.claude/statusline-command.sh"
  },
  "tui": "fullscreen",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "skipDangerousModePermissionPrompt": true,
  "voiceEnabled": true
}
