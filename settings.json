{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 7,
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "~/.claude/hooks/notify-idle.sh",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "idle_prompt"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "~/.claude/hooks/auto-format.sh",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "~/.claude/hooks/validate-bash-commands.py",
            "timeout": 5,
            "type": "command"
          },
          {
            "command": "~/.claude/hooks/log-git-commands.sh",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "~/.claude/hooks/validate-config.py",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "~/.claude/hooks/load-session-context.sh",
            "timeout": 10,
            "type": "command"
          },
          {
            "command": "~/.claude/hooks/session-start.js",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "~/.claude/hooks/session-end.js",
            "type": "command"
          },
          {
            "command": "~/.claude/hooks/evaluate-session.js",
            "type": "command"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Glob",
      "Grep",
      "Write(*.go)",
      "Write(*.md)",
      "Write(*.json, !settings.json, !.mcp.json)",
      "Write(*.yaml)",
      "Write(*.yml)",
      "Write(*.ts)",
      "Write(*.tsx)",
      "Write(*.py)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(dot:*)",
      "Bash(go:*)",
      "Bash(brew:*)",
      "Bash(bun:*)",
      "Bash(bunx:*)",
      "Bash(wc:*)",
      "Bash(cat:*)",
      "Skill(version-control)",
      "Bash(ls:*)"
    ],
    "defaultMode": "plan",
    "deny": ["Read(.env*)", "Write(.env*)", "Bash(sudo:*)"]
  },
  "statusLine": {
    "command": "bun run ~/.claude/statusline.js",
    "padding": 0,
    "type": "command"
  }
}
