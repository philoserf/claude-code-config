{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 7,
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Glob",
      "Grep",
      "Write(*.go)",
      "Write(*.md)",
      "Write(*.json, !settings.json, !.mcp.json)",
      "Write(*.yaml)",
      "Write(*.yml)",
      "Write(*.ts)",
      "Write(*.tsx)",
      "Write(*.py)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(dot:*)",
      "Bash(go:*)",
      "Bash(brew:*)",
      "Bash(bun:*)",
      "Bash(bunx:*)",
      "Bash(wc:*)",
      "Bash(cat:*)",
      "Skill(command-audit)",
      "Skill(git-workflow)",
      "Bash(ls:*)"
    ],
    "deny": ["Read(.env*)", "Write(.env*)", "Bash(sudo:*)"],
    "defaultMode": "plan"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify-idle.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/auto-format.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/log-git-commands.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "uvx --script ~/.claude/hooks/validate-bash-commands.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "uvx --script ~/.claude/hooks/validate-config.py",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/load-session-context.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bun run ~/.claude/statusline.js",
    "padding": 0
  }
}
