{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false"
  },
  "attribution": {
    "commit": "Co-Authored-By: Claude Code <noreply@anthropic.com>",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Edit",
      "Glob",
      "Grep",
      "Read",
      "Skill(cc-review)",
      "Skill(diff-review)",
      "Skill(vc-ship)",
      "Skill(vc-sync)",
      "Skill(walkthrough)",
      "Write(*.go)",
      "Write(*.json, !settings.json, !.mcp.json)",
      "Write(*.md)",
      "Write(*.py)",
      "Write(*.ts)",
      "Write(*.tsx)",
      "Write(*.yaml)",
      "Write(*.yml)",
      "Write(*.sh)",
      "Bash(brew:*)",
      "Bash(bun:*)",
      "Bash(bunx:*)",
      "Bash(claude plugin:*)",
      "Bash(fish:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(gitup:*)",
      "Bash(go:*)",
      "Bash(ls:*)",
      "Bash(shellcheck:*)",
      "Bash(shfmt:*)",
      "Bash(task:*)",
      "Bash(uv:*)",
      "Bash(uvx:*)",
      "Bash(biome:*)",
      "Bash(gofumpt:*)",
      "Bash(golangci-lint:*)",
      "Bash(exiftool:*)",
      "Bash(awk:*)",
      "Bash(cat:*)",
      "Bash(cut:*)",
      "Bash(diff:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(obsidian:*)",
      "Bash(jq:*)",
      "Bash(printf:*)",
      "Bash(sed:*)",
      "Bash(sort:*)",
      "Bash(tail:*)",
      "Bash(tr:*)",
      "Bash(tsc:*)",
      "Bash(uniq:*)",
      "Bash(wc:*)",
      "Bash(xargs:*)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:platform.claude.com)",
      "WebFetch(domain:resources.anthropic.com)",
      "WebFetch(domain:taskfile.dev)",
      "WebSearch",
      "mcp__github__issue_write"
    ],
    "deny": [
      "Edit(.env*)",
      "Read(.env*)",
      "Write(.env*)",
      "Read(~/.aws/**)",
      "Read(~/.azure/**)",
      "Read(~/.docker/config.json)",
      "Read(~/.git-credentials)",
      "Read(~/.gnupg/**)",
      "Read(~/.kube/**)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Read(~/Library/Keychains/**)",
      "Read(**/node_modules/**)",
      "Read(**/.DS_Store)",
      "Read(**/package-lock.json)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(pnpm:*)",
      "Bash(pnpx:*)",
      "Bash(sudo:*)",
      "Bash(yarn:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/load-session-context.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/stale-branch-guard.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "HOOK_EVENT=SessionStart ~/.claude/hooks/suggest-compact.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/validate-bash-commands.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/config-protection.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/prompt-injection-guard.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/auto-format.sh",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/suggest-compact.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/context-monitor.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/log-event.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/log-event.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/log-event.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/log-event.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/log-event.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "PermissionDenied": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/log-event.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/log-event.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/log-event.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/log-event.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/log-event.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/log-event.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "Elicitation": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/log-event.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "ElicitationResult": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/log-event.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/log-event.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/log-event.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "Setup": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/log-event.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/log-event.sh",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c 'plugin_dir=$(ls -d \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}\"/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | awk -F/ '\"'\"'{ print $(NF-1) \"\\t\" $(0) }'\"'\"' | sort -t. -k1,1n -k2,2n -k3,3n -k4,4n | tail -1 | cut -f2-); exec \"/opt/homebrew/bin/bun\" --env-file /dev/null \"${plugin_dir}src/index.ts\"'",
    "refreshInterval": 300
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "obsidian@obsidian-skills": true,
    "gh-cli@trailofbits": true,
    "modern-python@trailofbits": true,
    "claude-hud@claude-hud": true,
    "superpowers@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "obsidian-skills": {
      "source": {
        "source": "github",
        "repo": "kepano/obsidian-skills"
      }
    },
    "trailofbits": {
      "source": {
        "source": "github",
        "repo": "trailofbits/skills"
      }
    },
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    }
  },
  "spinnerTipsEnabled": false,
  "tui": "fullscreen",
  "prefersReducedMotion": true,
  "skipDangerousModePermissionPrompt": true,
  "theme": "auto",
  "verbose": true,
  "showTurnDuration": false,
  "terminalProgressBarEnabled": false,
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "voiceEnabled": true
}
