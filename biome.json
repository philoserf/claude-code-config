{
  "$schema": "https://biomejs.dev/schemas/latest/schema.json",
  "files": {
    "includes": ["**/*"],
    "ignoreUnknown": true
  },
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "linter": { "enabled": true, "rules": { "recommended": true } },
  "formatter": { "enabled": true, "indentStyle": "space", "indentWidth": 2 }
}
